<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:padding="20dp"
    >

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/settings_title"
        android:textColor="#E0E0E0"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- FOV Setting -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_fov_label"
        android:textColor="#B0B0B0"
        android:textSize="15sp"
        android:layout_marginBottom="2dp" />

    <TextView
        android:id="@+id/tv_fov_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#4FC3F7"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <SeekBar
        android:id="@+id/sb_fov"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:max="50"
        android:progress="25" />

    <!-- Height Setting -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_height_label"
        android:textColor="#B0B0B0"
        android:textSize="15sp"
        android:layout_marginBottom="2dp" />

    <TextView
        android:id="@+id/tv_height_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#4FC3F7"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <SeekBar
        android:id="@+id/sb_height"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:max="100"
        android:progress="50" />

    <!-- Buttons -->
    <LinearLayout
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_reset"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/settings_reset"
            android:textSize="15sp"
            android:layout_marginEnd="10dp"
            android:background="#37474F"
            android:textColor="#E0E0E0" />

        <Button
            android:id="@+id/btn_save"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/settings_save"
            android:textSize="15sp"
            android:layout_marginStart="10dp"
            android:background="#0D47A1"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_hint"
        android:textColor="#707070"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="12dp" />

</LinearLayout>
</ScrollView>